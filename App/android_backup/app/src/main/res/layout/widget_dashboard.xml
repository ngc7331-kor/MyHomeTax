<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <!-- Background (80% Alpha, Sync with LToBank) -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_glass_background"
        android:scaleType="fitXY"
        android:alpha="0.8" />

    <!-- Last Updated (Fixed at Bottom) -->
    <TextView
        android:id="@+id/txt_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="end"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp"
        android:text="최종 확인: --:--"
        android:textColor="#80FFFFFF"
        android:textSize="8sp" />

    <!-- Main Content Container (Positioned ABOVE the timestamp) -->
    <LinearLayout
        android:id="@+id/layout_data_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/txt_last_updated"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:gravity="top">

        <!-- Top Row: Logo & Title -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_widget_logo"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/txt_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_logo"
                android:layout_marginStart="6dp"
                android:text="우리집 세금"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_centerVertical="true" />

            <!-- Pending Badge (Right aligned) -->
            <LinearLayout
                android:id="@+id/layout_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/badge_background"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="승인대기"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="3dp"
                    android:textStyle="normal" />

                <TextView
                    android:id="@+id/txt_pending_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Balances Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txt_left_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="채원"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txt_left_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₩ 0"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txt_left_refund"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="환급액: ₩ 0"
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Right -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txt_right_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="도권"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txt_right_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₩ 0"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                 <TextView
                    android:id="@+id/txt_right_refund"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="환급액: ₩ 0"
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
