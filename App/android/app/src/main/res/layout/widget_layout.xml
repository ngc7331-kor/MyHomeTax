<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <!-- л°°кІҪ (80% нҲ¬лӘ…лҸ„) -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_glass_background"
        android:scaleType="fitXY"
        android:alpha="0.8" />

    <!-- мөңмў… нҷ•мқё мӢңк°„ (мҡ°н•ҳлӢЁ) -->
    <TextView
        android:id="@+id/txt_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="end"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp"
        android:text="мөңмў… нҷ•мқё: --:--"
        android:textColor="#80FFFFFF"
        android:textSize="8sp" />

    <!-- лЎңк·ёмқё н•„мҡ” л§ҲмҠӨнҒ¬ -->
    <LinearLayout
        android:id="@+id/txt_login_required"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:visibility="gone">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_logo"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="лЎңк·ёмқёмқҙ н•„мҡ”н•©лӢҲлӢӨ."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- л©”мқё мҪҳн…җмё  -->
    <LinearLayout
        android:id="@+id/layout_data_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/txt_last_updated"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="4dp">

        <!-- н—ӨлҚ” мҳҒм—ӯ (LToBankмҷҖ 100% лҸҷмқј к·ңкІ©) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_widget_logo"
                android:scaleType="fitCenter"
                android:layout_centerVertical="true" />
            <TextView
                android:id="@+id/txt_widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_logo"
                android:layout_marginStart="6dp"
                android:text="мҡ°лҰ¬м§‘ м„ёкёҲ"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_centerVertical="true" />
            
            <!-- м•Ңм•Ҫ UI (LToBank ліөм ң) -->
            <LinearLayout
                android:id="@+id/layout_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/badge_background"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:visibility="visible">
                <TextView
                    android:id="@+id/txt_badge_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="мҠ№мқё лҢҖкё°: "
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="3dp" />
                <TextView
                    android:id="@+id/txt_pending_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0кұҙ"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <!-- лҚ°мқҙн„° н‘ңмӢң мҳҒм—ӯ -->
        <LinearLayout
            android:id="@+id/layout_accounts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- мҷјмӘҪ кі„мўҢ (мұ„мӣҗ) -->
            <LinearLayout
                android:id="@+id/layout_left"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/txt_left_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="мұ„мӣҗ"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:id="@+id/layout_left_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/txt_left_amount_v"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txt_left_refund_v"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="нҷҳкёүм•Ў: 0"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
                
                <!-- мһҗл…Җмҡ© л Ҳмқҙм•„мӣғ -->
                <LinearLayout
                    android:id="@+id/layout_left_vertical_child"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/txt_left_amount_c"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="м„ёкёҲм•Ў: 0мӣҗ"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txt_left_refund_c"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="мқҙмһҗ: 0мӣҗ"
                        android:textColor="#CCFFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- мҳӨлҘёмӘҪ кі„мўҢ (лҸ„к¶Ң) -->
            <LinearLayout
                android:id="@+id/layout_right"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/txt_right_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="лҸ„к¶Ң"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:id="@+id/layout_right_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/txt_right_amount_v"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txt_right_refund_v"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="нҷҳкёүм•Ў: 0"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
                
                <!-- мһҗл…Җмҡ© л Ҳмқҙм•„мӣғ -->
                <LinearLayout
                    android:id="@+id/layout_right_vertical_child"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/txt_right_amount_c"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="м„ёкёҲм•Ў: 0мӣҗ"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txt_right_refund_c"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="мқҙмһҗ: 0мӣҗ"
                        android:textColor="#CCFFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
